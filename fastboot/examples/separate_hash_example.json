{
  "description": "System with separate dm-verity hash storage",
  "version": "1.0.0",
  "comment": "Useful for retrofitting verification to existing systems",
  
  "device": {
    "class": "rpi5",
    "variant": "8GB",
    "storage": {
      "type": "nvme",
      "sector_size": 512,
      "capacity": 64
    }
  },
  
  "layout": {
    "partitiontable": {
      "label": "gpt",
      "alignment": 4194304
    },
    
    "partitions": [
      {
        "num": 1,
        "size": 268435456,
        "typecode": "c12a7328-f81f-11d2-ba4b-00a0c93ec93b",
        "gptlabel": "efi",
        "simg": "efi.simg"
      },
      
      {
        "num": 2,
        "size": 2147483648,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "system",
        "simg": "system.simg",
        "verity": {
          "enabled": true,
          "mode": "separate",
          "hash_path": "/persistent/system.verity",
          "hash_algorithm": "sha256",
          "comment": "Hash stored separately in /persistent"
        }
      },
      
      {
        "num": 3,
        "size": 1073741824,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "config",
        "simg": "config.simg",
        "verity": {
          "enabled": true,
          "mode": "separate",
          "hash_path": "/persistent/config.verity",
          "hash_algorithm": "sha256"
        }
      },
      
      {
        "num": 4,
        "expand_to_fit": true,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "data",
        "comment": "Unencrypted data partition"
      }
    ]
  }
}

