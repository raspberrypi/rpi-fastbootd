{
  "description": "Raspberry Pi 5 - A/B System with dm-verity and LUKS",
  "version": "1.0.0",
  "created": "2025-10-31",
  
  "device": {
    "class": "rpi5",
    "variant": "8GB",
    "storage": {
      "type": "emmc",
      "sector_size": 512,
      "capacity": 32
    }
  },
  
  "layout": {
    "partitiontable": {
      "label": "gpt",
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "alignment": 4194304,
      "slots": {
        "enabled": true,
        "count": 2,
        "suffix": ["_a", "_b"],
        "default_slot": "a"
      }
    },
    
    "partitions": [
      {
        "name": "boot",
        "slotted": true,
        "size": 268435456,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "boot",
        "simg": "boot.simg",
        "verity": {
          "enabled": true,
          "mode": "appended",
          "data_size": 260046848,
          "hash_algorithm": "sha256",
          "comment": "Kernel + device tree + initramfs verified"
        }
      },
      
      {
        "name": "system",
        "slotted": true,
        "size": 2147483648,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "system",
        "simg": "system.simg",
        "verity": {
          "enabled": true,
          "mode": "appended",
          "data_size": 2040109056,
          "hash_algorithm": "sha256",
          "comment": "Root filesystem verified"
        }
      },
      
      {
        "name": "vendor",
        "slotted": true,
        "size": 1073741824,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "vendor",
        "simg": "vendor.simg",
        "verity": {
          "enabled": true,
          "mode": "appended",
          "data_size": 1020054528,
          "hash_algorithm": "sha256",
          "comment": "Vendor binaries and firmware verified"
        }
      },
      
      {
        "name": "userdata",
        "slotted": false,
        "expand_to_fit": true,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "userdata",
        "luks": {
          "version": 2,
          "cipher": "aes-xts-plain64",
          "key_size": 256,
          "hash": "sha256",
          "sector_size": 512,
          "mname": "userdata_crypt",
          "label": "userdata_encrypted",
          "comment": "Encrypted user data - shared between A/B slots"
        }
      }
    ]
  }
}

