{
  "description": "Simple verified system - No A/B, dm-verity + LUKS",
  "version": "1.0.0",
  
  "device": {
    "class": "rpi5",
    "variant": "4GB",
    "storage": {
      "type": "sd",
      "sector_size": 512,
      "capacity": 16
    }
  },
  
  "layout": {
    "partitiontable": {
      "label": "gpt",
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "alignment": 4194304
    },
    
    "partitions": [
      {
        "num": 1,
        "size": 268435456,
        "typecode": "c12a7328-f81f-11d2-ba4b-00a0c93ec93b",
        "gptlabel": "boot",
        "simg": "boot.simg",
        "comment": "UEFI boot partition - no verification"
      },
      
      {
        "num": 2,
        "size": 2147483648,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "rootfs",
        "simg": "rootfs.simg",
        "verity": {
          "enabled": true,
          "mode": "appended",
          "data_size": 2040109056,
          "hash_algorithm": "sha256"
        },
        "comment": "Root filesystem - read-only, verified"
      },
      
      {
        "num": 3,
        "expand_to_fit": true,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "userdata",
        "luks": {
          "version": 2,
          "cipher": "aes-xts-plain64",
          "key_size": 256,
          "hash": "sha256",
          "mname": "userdata",
          "label": "encrypted_data"
        },
        "comment": "User data - read-write, encrypted"
      }
    ]
  }
}

