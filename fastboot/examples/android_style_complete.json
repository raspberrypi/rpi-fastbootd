          "enabled": true,
          "mode": "appended",
          "data_size": 260046848,
          "hash_algorithm": "sha256",
          "block_size": 4096
        },
        "description": "Kernel, device tree, initramfs"
      },
      
      {
        "name": "system",
        "slotted": true,
