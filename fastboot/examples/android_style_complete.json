{
  "description": "Complete Android-style device with A/B, dm-verity, and LUKS",
  "version": "1.0.0",
  "author": "Device Provisioning Team",
  "build_date": "2025-10-31",
  
  "device": {
    "class": "rpi5",
    "variant": "8GB",
    "serial": "RPI5-2024-12345",
    "storage": {
      "type": "emmc",
      "sector_size": 512,
      "capacity": 64,
      "device_path": "/dev/mmcblk0"
    }
  },
  
  "layout": {
