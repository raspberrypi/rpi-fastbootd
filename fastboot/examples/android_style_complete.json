          "data_size": 1020054528,
          "hash_algorithm": "sha256",
          "block_size": 4096
        },
        "description": "Vendor-specific binaries and firmware"
      },
      
      {
        "name": "product",
        "slotted": true,
        "size": 536870912,
        "typecode": "0fc63daf-8483-4772-8e79-3d69d8477de4",
        "gptlabel": "product",
        "gptuuid": "auto",
        "simg": "product.simg",
        "verity": {
          "enabled": true,
