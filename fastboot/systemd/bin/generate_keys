#!/bin/sh

set -e

## Generate the keys parts
if /usr/local/bin/rpi-otp-private-key -c; then
    printf "yes\r\n" > /data/privkey-already-set
else
    printf "no\r\n" > /data/privkey-already-set
    # Generate a key!
	openssl ecparam -name prime256v1 -genkey -noout -out private_key.pem
	openssl ec -in private_key.pem -text -noout | awk '/priv:/{flag=1; next} /pub:/{flag=0} flag' | tr -d ' \n:' | head -n1 > d.hex
    [ ! -f /etc/rpi-no-generate-duk ] && /usr/local/bin/rpi-otp-private-key -y -w "$(cat d.hex)"

fi

PRIVATE_KEY=$(/usr/local/bin/rpi-otp-private-key -b | base64 -w0)
# Create a complete EC private key structure that OpenSSL can use
PRIVKEY_HEX=$(echo "${PRIVATE_KEY}" | base64 -d | xxd -p -c 32 | tr -d '\n')

# Generate a template and replace the private key portion
openssl ecparam -name prime256v1 -genkey -noout -out /tmp/template.pem
TEMPLATE_HEX=$(openssl ec -in /tmp/template.pem -text -noout | grep -A 3 "priv:" | tail -n +2 | tr -d ' \n:')

# Replace the template's private key portion
sed "s/${TEMPLATE_HEX}/${PRIVKEY_HEX}/g" /tmp/template.pem > /tmp/tempkey.pem

# Generate public key
openssl ec -in /tmp/tempkey.pem -pubout -out /data/key.pub

# Cleanup
rm -f /tmp/template.pem /tmp/tempkey.pem
