#!/bin/sh

set -e

printf "version = 0.4\r\n" > /data/fastboot.cfg
{
    printf "product = %s\r\n" "$(cat /sys/firmware/devicetree/base/model)"
    printf "serialno = %s\r\n" "$(cat /proc/device-tree/serial-number)"
    printf "is-userspace = yes\r\n"
    printf "device-directory = /dev/# DANGEROUS\r\n"
    printf "max-download-size = 0x10000000# 256MiB\r\n"
} >> /data/fastboot.cfg

## Identify if a key has already been written
if /usr/local/bin/rpi-otp-private-key -c; then
    printf "yes\r\n" >> /data/privkey-already-set
else
    printf "no\r\n" >> /data/privkey-already-set
fi

# Use base64 encoded private key as LUKS passphrase
PRIVATE_KEY=$(/usr/local/bin/rpi-otp-private-key -b | base64 -w0)
if [ -n "${PRIVATE_KEY}" ]; then
	printf "%s" "${PRIVATE_KEY}" > /data/fastboot.key
	printf "%s\r\n" "${PRIVATE_KEY}" >> /data/private.key

	# Apply correct ed25519 DER header to generate compliant private key
	{
	    printf MC4CAQAwBQYDK2VwBCIEIA== | base64 -d -
	    base64 -d /data/fastboot.key
	} > /data/key.der

	# Generate public key
	printf "%s\r\n" "$(openssl pkey -in /data/key.der -inform DER -pubout | sed '/PUBLIC/d' | tr -d '\n')" >> /data/key.pub
fi
